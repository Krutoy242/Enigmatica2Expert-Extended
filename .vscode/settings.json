  // world-gen.json, coverage-*, .gitignore, ./dev/automation/betterquesting/*, ./dev/lang/tmp*, ./config/BiomeTweaker/output/biome/*, ./node_modules/*, ./dev/default_configs/*, ./config/tellme/*, ./scripts/wrap/*, ./crash-reports/*, ./.git/*, ./CHANGELOG*, ./minecraftinstance.json*, ./assets/*, ./dumps/*, ./saves/* , ./*.zsrc, *.log, *aspects.json, blocks.cfg
  "search.exclude": {
    "./assets": true,
    "./dumps": true,
    "./saves": true,
    ".git/*": true,
    ".gitignore": true,
    "*.log": true,
    "*.zsrc": true,
    "CHANGELOG*": true,
    "config/*aspects.json": true,
    "config/BiomeTweaker/output/biome/*": true,
    "config/jeresources/world-gen.json": true,
    "config/tellme/*": true,
    "crash-reports/*": true,
    "dev/automation/betterquesting/*": true,
    "dev/default_configs/*": true,
    "dev/lang/tmp*": true,
    "minecraftinstance.json*": true,
    "node_modules": true,
    "scripts/wrap/*": true
  },
  "files.associations": {
    "*.png.mcmeta": "json",
    "config/cofh/world/**/*.json": "properties"
  },

  "mc-tools.modlist.baselinePath": "../E2E-unchanged/minecraftinstance.json",
  "mc-tools.modlist.ignorePath": "dev/.devonly.ignore",
  "mc-tools.modlist.templatePath": "dev/tools/modlist_template.md",
  "mc-tools.modlist.outputPath": "MODS.md",
  "mc-tools.modlist.sortBy": "addonID",
  "mc-tools.manifest.ignorePath": "dev/.devonly.ignore",
  "mc-tools.manifest.inputPath": "minecraftinstance.json",
  "mc-tools.modTracker.inputPath": "minecraftinstance.json",
  "mc-tools.modTracker.configWatchPattern": "config/**/*",
  "mc-tools.modTracker.globalFiles": ["MODS.md", ".gitignore", ".gitattributes"],
  "mc-tools.modTracker.ignoredMappingPatterns": ["mods/*", "minecraftinstance.json", "manifest*.json", "MODS.md", ".gitignore", ".gitattributes"],
  "mc-tools.debugLog.defaultMatchRegex": ".*(?:WARN|ERROR|FATAL).*",
  "mc-tools.crafttweakerLog.fileExtensions": [".zs"]
}
